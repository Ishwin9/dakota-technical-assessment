# Dakota Analytics Technical Assessment
# Copy to .env and configure with your values

# Database
POSTGRES_DB=energy_analytics
POSTGRES_USER=dakota_user
POSTGRES_PASSWORD=change_me
# Host-side port Postgres is published on (container always uses 5432 internally).
# Defaults to 5433 to avoid clashing with a native Postgres install on 5432.
POSTGRES_HOST_PORT=5433

EIA_API_KEY=your_key_here

# dbt runs locally (dbt-postgres) against the `postgres` service above, reusing
# the POSTGRES_* credentials -- no separate dbt credentials needed.

# Shared JWT signing secret across all Airflow containers (scheduler, dag-processor,
# triggerer, api-server) -- must be identical on every container or internal
# service-to-service auth fails. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_JWT_SECRET=generate_a_random_value

# Add additional environment variables as needed for your implementation
